generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  GUEST
}

enum RoomType {
  SINGLE
  DOUBLE
  DELUXE
  SUITE
  PENTHOUSE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(GUEST)
  phone     String?
  address   String?
  avatar    String?  // UploadThing image URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings       Booking[]
  roomStatusLogs RoomStatusLog[]

  @@index([email])
  @@index([role])
}

model Room {
  id          String     @id @default(cuid())
  number      String     @unique
  type        RoomType
  status      RoomStatus @default(AVAILABLE)
  pricePerNight Float
  floor       Int
  capacity    Int        @default(2)
  description String?
  amenities   String[]   // ["WiFi", "AC", "TV", ...]
  images      String[]   // array of image URLs
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  bookings       Booking[]
  roomStatusLogs RoomStatusLog[]

  @@index([status])
  @@index([type])
}

model Booking {
  id         String        @id @default(cuid())
  userId     String
  roomId     String
  checkIn    DateTime
  checkOut   DateTime
  status     BookingStatus @default(PENDING)
  totalPrice Float
  adults     Int           @default(1)
  children   Int           @default(0)
  notes      String?

  // ── FNMIS (Foreign Nationals Management Information System) ─────────────────
  guestNationality  String?    // e.g. "Indian", "American", "Chinese"
  passportNumber    String?    // Passport / citizenship number
  purposeOfVisit    String?    // "Tourism", "Business", "Trekking", "Medical"
  fnmisReported     Boolean    @default(false)
  fnmisReportedAt   DateTime?

  // ── IRD Billing (Inland Revenue Dept) ────────────────────────────────────────
  invoiceNumber     String?    // Auto-generated once invoice is issued
  invoiceIssuedAt   DateTime?  // When invoice was issued (becomes immutable after this)
  creditNoteRef     String?    // If this booking was reversed, reference to credit note

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  // Payment metadata
  paymentProvider     String?
  paymentTransactionId String?
  refunded            Boolean   @default(false)
  refundedAt          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  refundRequests RefundRequest[]

  @@index([userId])
  @@index([roomId])
  @@index([checkIn, checkOut])
  @@index([createdAt])
  @@index([status])
}

model RoomStatusLog {
  id        String     @id @default(cuid())
  roomId    String
  status    RoomStatus
  updatedBy String     // userId of staff/admin who made the change
  notes     String?
  createdAt DateTime   @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [updatedBy], references: [id])

  @@index([roomId])
}

model RefundRequest {
  id         String   @id @default(cuid())
  bookingId  String
  requestedBy String
  reason     String?
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED, PROCESSED
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}
